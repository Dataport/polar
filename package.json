{
	"name": "polar-monorepo",
	"private": true,
	"type": "module",
	"description": "monorepository to build masterportalAPI-based map clients",
	"author": "Dataport AöR <polar@dataport.de>",
	"license": "EUPL-1.2",
	"engines": {
		"node": "^22.16.0",
		"npm": "^10.9.2"
	},
	"workspaces": [
		"packages/clients/*",
		"packages/polar"
	],
	"scripts": {
		"build": "nx build @polar/polar",
		"snowbox": "nx dev @polar/client-snowbox",
		"snowbox-prod": "nx dev @polar/client-snowbox-prod",
		"clean": "nx reset && rimraf --glob packages/**/{.cache,dist,docs,node_modules} {.cache,dist} node_modules",
		"lint": "eslint --cache .",
		"lint:ci": "eslint .",
		"lint:fix": "npm run lint -- --fix",
		"tsc:ci": "tsc --noEmit"
	},
	"devDependencies": {
		"@dataport/eslint-config-geodev": "^0.3.3",
		"@nx/js": "21.2.1",
		"@nx/vite": "21.2.1",
		"@nx/web": "21.2.1",
		"eslint": "^9.29.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-prettier": "^5.5.0",
		"nx": "21.2.1",
		"prettier": "^3.5.3",
		"rimraf": "^6.0.1",
		"typescript": "^5.8.3"
	},
	"dependencies": {}
}
