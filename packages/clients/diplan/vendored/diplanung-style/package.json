{
  "name": "diplanung-style",
  "version": "13.2.0",
  "description": "Gemeinsam genutzte DiPlanung Design-Ressourcen",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "web-types": "./web-types.json",
  "types": "./dist/index.d.ts",
  "scripts": {
    "create-component": "node ./scripts/create-component.js && git add src/components -A",
    "storybook": "SET NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6007",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly && git add .",
    "build:storybook": "SET NODE_OPTIONS=--openssl-legacy-provider && storybook build",
    "lint:js": "npx eslint src stories tests",
    "lint:js:fix": "npx eslint src stories tests --fix",
    "lint:style": "npx stylelint \"src/**/*.{css,scss,vue}\" --ignore-path .gitignore",
    "lint:style:fix": "npx stylelint \"src/**/*.{css,scss,vue}\" --ignore-path .gitignore --fix",
    "lint:typescript": "vue-tsc",
    "lint:all": "concurrently -c red,yellow,blue \"npm run lint:js\" \"npm run lint:style\" \"npm run lint:typescript\"",
    "lint-staged": "lint-staged",
    "release": "release-it --only-version --no-git",
    "release:rc": "release-it --preRelease=rc --only-version --no-git",
    "clean": "del-cli storybook-static CHANGELOG.md",
    "prettier": "prettier -w -u",
    "prepare": "husky",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:update": "vitest --run -u",
    "test:coverage": "vitest --run --coverage",
    "generate-types": "vue-docgen-web-types"
  },
  "author": {
    "name": "Behörde für Stadtentwicklung und Wohnen Hamburg"
  },
  "contributors": [
    {
      "name": "]init[ AG",
      "url": "https://www.init.de/"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://www.dev.diplanung.de/DefaultCollection/DiPlanStyle/_git/diplan-style"
  },
